    border-radius: 50%;
} 
span.span_bg_color {
    padding-right: 0px; 
}
.radio-wrapper.product-form__item .single-option-radio .__itemWraper {
    max-width: 50px;
}
.product-single__quantity, .__frm_2, .__frm_1  {
  	width: 30% !important;
    max-width: 25% !important;
}
.__frm_1  {
    max-width: 30% !important;
}
.sf_PB_banner_right .__frm_1 label.single-option-radio__label {
    width: unset !important;
    max-width: 35px !important;
} 
.sf_PB_banner_right label.single-option-radio__label {
    max-width: 55px !important;
}  
.product-single__quantity  {
    flex-wrap: nowrap !important;
}
.__frm_2 label.single-option-radio__label {
    max-width: 85px !important;
}  
.radio-wrapper.js.product-form__item.__frm_2 {
    margin-bottom: 0px!important;
} 
  

@media (max-width: 1285px) {
	
	}

@media only screen and (min-width: 100px) and (max-width: 1100px) {
	.sf_PB_banner_right .__price_button .col-md-12.no-padding {flex-direction: row;}
    .sf_PB_banner_right .__frm_1 label.single-option-radio__label {
        width: 100%!important;
        max-width: 100% !important;
    }
    .sf_PB_banner_right label.single-option-radio__label {
        max-width: 100% !important;
    }
    .peePadVarientsSC .product-form__item.__frm_2 div#ProductSelect-option-1 {
        flex-wrap: wrap;
    }
    .product-single__quantity {
        flex-wrap: wrap !important;
    }
    .pawtectBlanketProductContainer .radio-wrapper.js.product-form__item.__frm_2 label.single-option-radio__label {
        margin-bottom: 0px!important;
    }
  	.sf_PB_banner_right label.single-option-radio__label {
        align-items: center !important;
        border-top: 1px solid #e8e8e8 !important;
        overflow: visible;
        margin: 5px 0 !important;
    } 
    span.span_bg_color {
        background: white;
        padding: 0 5px;
        transform: translateY(-10px);
    }
    div#rc_container {
        margin-top: 0 !important;
    }
	
}

@media (max-width: 767px){
	section.pb_slider_35be7bef-965e-4797-985d-ebe490ecc347.sss_slider {display: block !important;}
	.sf_PB_banner_right .__price_button .col-md-12.no-padding .product-single__add-to-cart {justify-content: center; padding: 20px 0!important; margin:  0!important; margin-top: 30px !important; border-top: 1px solid #c6c6c6; border-bottom: 1px solid #c6c6c6;}
	.product-single__quantity {border-bottom: 0px solid #cccccc;}
	.product-single__quantity label span.span_bg_color {margin-top: 0px;}
	.sf_PB_banner_right label.single-option-radio__label:after {background: transparent;}
	.radio-wrapper.js.product-form__item.__frm_1 span.span_bg_color {padding: 0; display: block; text-align: center !important; margin: 0px auto;}
	#PawtectBlanketSlider5 .bc_slide {padding-top: 60%;}
	.sss_slider {display: block !important;}

  
  	.product-single__quantity .js-qty {
        justify-content: center; 
    }
  	.product-single__quantity label span.span_bg_color {
        padding:  0 10px;
    }
    label[for="ProductSelect-option-Wipes Quantity-100"] {
        width: 40px !important;
        max-width: 40px !important;
        height: 40px;
    }
  
}
</style>
  <script>
// special feature in product page
  $(document).on("click",".Special_Features_content .inner_text h3",function(){
    $(".sf_c_content.is_active_slide").slideUp();  
    $(".inner_text .sf_c_content").removeClass('is_active_slide');
    $(".inner_text h3").removeClass('is_icon_rotate');
    $(this).addClass('is_icon_rotate');	
	var spl_id = jQuery(this).attr('spf_id');
	$("#"+ spl_id).addClass('is_active_slide');
  $(".sf_c_content.is_active_slide").slideDown('slow');  
  })
  </script>