<!-- snippets/product-uses-snippet.liquid-->
{% include 'product-footer-snippet' %}
<!-- review widget -->
<!--Stamped - Begin Main Widget -->
<div id="stamped-main-widget"   
data-widget-style="standard" 
data-product-id="{{ product.id }}"   
data-name="{{ product.title | escape }}"   
data-url="{{ shop.url }}{{ product.url }}"   
data-image-url="{{ product.featured_image | product_img_url: "large" |replace: '?', '%3F' | replace: '&','%26'}}" 
data-description="{{ product.description | escape }}"   
data-product-sku="{{product.handle}}"
data-product-type="{{product.type}}">   
{{ product.metafields.stamped.reviews }}   
</div>
<!-- Stamped - End Main Widget -->
<!--{ % include 'judgeme_widgets', widget_type: 'judgeme_review_widget', concierge_install: true %}-->
{% schema %}
  {
    "name": "Footer Content",
    "settings": [	  
	  {"type":"text","id":"cusreviewheadline","label":"FAQ Heading","default":"Frequently Asked Questions"}		
    ],
	"blocks" : [{
			"type":"faq",
			"name":"FAQ Left",
			"limit": 12,
			"settings":[
				  {"type": "text","id":"faq_title","label":"Faq Heading"},
				  {"type": "html","id":"faq_data","label":"Faq Content"}
				]
			},
			{
			"type":"faq_right",
			"name":"FAQ Right",
			"limit": 12,
			"settings":[
				  {"type": "text","id":"faq_title_r","label":"Faq Heading"},
				  {"type": "html","id":"faq_data_r","label":"Faq Content"}
				]
			}]
  }
{% endschema %}
<script type="text/javascript">
document.addEventListener('DOMContentLoaded', () => {
  /* JS code for inline play */
  let buttons = document.querySelectorAll('.inline_video.img');
  buttons.forEach((button) => {
    button.addEventListener('click', (e) => {
      console.log(e.target);
      let videoId = button.getAttribute('video');
      if (!videoId) return;
      let videoPath = 'https://www.youtube.com/embed/' + videoId + '?autoplay=1&rel=0';
      let ifrm = document.createElement("iframe");
      ifrm.setAttribute('src', videoPath);
      ifrm.setAttribute('allow', 'autoplay')
      ifrm.style.width = '100%';
      ifrm.style.height = '350px';
      ifrm.style.border = 'none';
      button.classList.remove('img');
      button.classList.add('playing');
      button.children[0].innerHTML = '';
      button.children[0].appendChild(ifrm);
    },{once:true});
  });
});
</script>